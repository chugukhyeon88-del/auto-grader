rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /exams/{examId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }
    match /submissions/{submissionId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }
  }
}
